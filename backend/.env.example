GEMINI_API_KEY=your_google_ai_studio_key
GOOGLE_FACT_CHECK_API_KEY=your_optional_google_fact_check_key
# Data directory (default: ./data for local dev, /app/data for Docker/Render)
DATA_DIR=./data
# ChromaDB storage (relative to DATA_DIR)
CHROMADB_PATH=./data/chromadb
SCRAPE_DELAY=1.0
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173